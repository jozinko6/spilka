// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Admin ────────────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Menu Categories ─────────────────────────────────────────
model MenuCategory {
  id     String     @id @default(cuid())
  title  String
  slug   String     @unique
  icon   String     // lucide icon name
  order  Int        @default(0)
  items  MenuItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Menu Items (Jedálny lístok) ────────────────────────────
model MenuItem {
  id          String       @id @default(cuid())
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       String       // e.g. "9,90"
  weight      String?      // e.g. "200 g"
  allergens   String?      // e.g. "1, 3, 7"
  badge       String?      // e.g. "Bestseller", "Tip šéfkuchára"
  isNew       Boolean      @default(false)
  order       Int          @default(0)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── Daily Menu (Ponuka dňa) ────────────────────────────────
model DailyMenu {
  id          String   @id @default(cuid())
  dayOfWeek   Int      // 1=Monday, 2=Tuesday, ..., 5=Friday
  soup        String
  soupAllergens  String?
  main1       String
  main1Allergens String?
  main2       String
  main2Allergens String?
  special     String?
  specialAllergens String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dayOfWeek])
}

// ─── Events (Akcie) ────────────────────────────────────────
model Event {
  id          String   @id @default(cuid())
  title       String
  date        String   // ISO date string e.g. "2026-04-27"
  time        String?  // e.g. "19:00"
  description String?
  organizer   String?
  type        String   // "quiz", "music", "valentine", "other"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Gallery Images ────────────────────────────────────────
model GalleryImage {
  id        String   @id @default(cuid())
  src       String   // URL or path
  alt       String
  label     String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Restaurant Tables ──────────────────────────────────────
model Table {
  id          String   @id @default(cuid())
  number      Int      @unique // table number e.g. 1, 2, 3
  name        String?  // e.g. "Pri okne", "Terasa"
  seats       Int      @default(4)
  area        String?  // e.g. "interior", "terrace", "vip"
  active      Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Orders ──────────────────────────────────────────────────
model Order {
  id          String     @id @default(cuid())
  tableId     String
  table       Table      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableNumber Int        // denormalized for convenience
  status      String     @default("received") // received, preparing, ready, served, paid, cancelled
  customerNote String?   // special requests from customer
  totalItems  Int        @default(0)
  totalPrice  String     @default("0") // e.g. "29,70"
  items       OrderItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Order Items ─────────────────────────────────────────────
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String? // nullable in case menu item is deleted
  name      String   // denormalized: item name at time of order
  price     String   // denormalized: item price at time of order
  quantity  Int      @default(1)
  note      String?  // e.g. "bez cibuľe"
  createdAt DateTime @default(now())
}
