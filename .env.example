# ──────────────────────────────────────────────
# SPILKA Terasa — Environment premenné
# ──────────────────────────────────────────────
# Skopírujte tento súbor ako .env a upravte hodnoty:
#   cp .env.example .env
# ──────────────────────────────────────────────

# Cesta k SQLite databáze
# Pre relatívnu cestu (odporúčané):
DATABASE_URL=file:./db/custom.db
# Pre absolútnu cestu:
# DATABASE_URL=file:/var/www/spilka-terasa/db/custom.db

# Port, na ktorom beží web server (voliteľné, predvolené: 3000)
PORT=3000

# Verejná URL stránky (pre SEO a zdieľanie)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Pre produkciu nastavte:
# NEXT_PUBLIC_SITE_URL=https://vasa-domena.sk
